          "type": "integer",
          "primaryKey": true,
          "description": "Unique employee identifier."
        },
        {
          "name": "employee_name",
          "type": "varchar",
          "description": "Full name of the employee."
        },
        {
          "name": "email",
          "type": "varchar",
          "description": "Employee email."
        },
        {
          "name": "department_id",
          "type": "integer",
          "description": "Department where the employee belongs."
        },
        {
          "name": "manager_id",
          "type": "integer",
          "description": "Employee ID of the reporting manager."
        },
        {
          "name": "job_level",
          "type": "varchar",
          "description": "Internal job level such as L2, L3, L4, L5, L6."
        },
        {
          "name": "hire_date",
          "type": "date",
          "description": "Employee joining date."
        },
        {
          "name": "employment_status",
          "type": "varchar",
          "description": "Current employment status."
        }
      ]
    },
    {
      "name": "performance_reviews",
      "properties": {
        "description": "Employee performance review outcomes including score, potential, promotion recommendation, and attrition risk."
      },
      "tableReference": {
        "catalog": "employee_demo",
        "schema": "public",
        "table": "performance_reviews"
      },
      "columns": [
        {
          "name": "review_id",
          "type": "integer",
          "primaryKey": true,
          "description": "Unique review identifier."
        },
        {
          "name": "employee_id",
          "type": "integer",
          "description": "Reviewed employee."
        },
        {
          "name": "review_period",
          "type": "varchar",
          "description": "Review period such as 2024-H1."
        },
        {
          "name": "performance_score",
