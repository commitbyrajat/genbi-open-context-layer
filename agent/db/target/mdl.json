        "description": "Project portfolio with project type, dates, budget, and status."
      },
      "tableReference": {
        "catalog": "employee_demo",
        "schema": "public",
        "table": "projects"
      },
      "columns": [
        {
          "name": "project_id",
          "type": "integer",
          "primaryKey": true,
          "description": "Unique project identifier."
        },
        {
          "name": "project_name",
          "type": "varchar",
          "description": "Project name."
        },
        {
          "name": "project_type",
          "type": "varchar",
          "description": "Type of project."
        },
        {
          "name": "start_date",
          "type": "date",
          "description": "Project start date."
        },
        {
          "name": "end_date",
          "type": "date",
          "description": "Project end date."
        },
        {
          "name": "budget",
          "type": "float",
          "description": "Approved project budget."
        },
        {
          "name": "project_status",
          "type": "varchar",
          "description": "Current project status."
        }
      ]
    },
    {
      "name": "salaries",
      "properties": {
        "description": "Employee salary history with effective date, annual salary, and currency."
      },
      "tableReference": {
        "catalog": "employee_demo",
        "schema": "public",
        "table": "salaries"
      },
      "columns": [
        {
          "name": "salary_id",
          "type": "integer",
          "primaryKey": true,
          "description": "Unique salary record identifier."
        },
        {
          "name": "employee_id",
          "type": "integer",
          "description": "Employee receiving salary."
        },
        {
          "name": "effective_from",
          "type": "date",
          "description": "Salary effective date."
        },
        {
          "name": "annual_salary",
          "type": "float",
