{
  "catalog": "wren",
  "schema": "public",
  "models": [
    {
      "name": "departments",
      "properties": {
        "description": "Company departments, business units, and office locations."
      },
      "tableReference": {
        "catalog": "employee_demo",
        "schema": "public",
        "table": "departments"
      },
      "columns": [
        {
          "name": "department_id",
          "type": "integer",
          "primaryKey": true,
          "description": "Unique department identifier."
        },
        {
          "name": "department_name",
          "type": "varchar",
          "description": "Department name."
        },
        {
          "name": "business_unit",
          "type": "varchar",
          "description": "Larger business unit."
        },
        {
          "name": "location",
          "type": "varchar",
          "description": "Primary department location."
        }
      ]
    },
    {
      "name": "employee_projects",
      "properties": {
        "description": "Many-to-many mapping between employees and projects, including allocation percentage and role."
      },
      "tableReference": {
        "catalog": "employee_demo",
        "schema": "public",
        "table": "employee_projects"
      },
      "columns": [
        {
          "name": "employee_project_id",
          "type": "integer",
          "primaryKey": true,
          "description": "Unique employee-project assignment identifier."
        },
        {
          "name": "employee_id",
          "type": "integer",
          "description": "Employee assigned to the project."
        },
        {
          "name": "project_id",
          "type": "integer",
          "description": "Project assigned to the employee."
        },
        {
          "name": "allocation_percent",
          "type": "float",
          "description": "Employee allocation percentage on the project."
        },
        {
          "name": "role_on_project",
          "type": "varchar",
          "description": "Employee role on the project."
        },
        {
          "name": "billable",
          "type": "boolean",
          "description": "Whether the employee assignment is billable."
        }
      ]
    },
    {
